<Window x:Class="CAAutomationHub.Wpf.Dialogs.RealtimeEventLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dashboard="clr-namespace:CAAutomationHub.Wpf.Models.Dashboard"
        Title="최근 이벤트 로그"
        Width="1060"
        Height="680"
        MinWidth="880"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="SeverityBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#34506A"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Critical}">
                    <Setter Property="Background" Value="#8F2D2D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Warning}">
                    <Setter Property="Background" Value="#7A5A1A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Info}">
                    <Setter Property="Background" Value="#1F5B73"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SeverityBarStyle" TargetType="Border">
            <Setter Property="Background" Value="#4E9DC2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Critical}">
                    <Setter Property="Background" Value="#FF5A5A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Warning}">
                    <Setter Property="Background" Value="#F4C542"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static dashboard:EventSeverity.Info}">
                    <Setter Property="Background" Value="#50B2FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="최근 이벤트 로그" Foreground="White" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#1D6F47" CornerRadius="10" Padding="9,3" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LiveIndicatorText}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Auto Scroll"
                              IsChecked="{Binding IsAutoScrollEnabled}"
                              Foreground="White"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    <Button Content="{Binding PauseResumeText}"
                            Command="{Binding PauseResumeCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="88"
                            Margin="0,0,8,0"/>
                    <Button Content="Close"
                            Click="OnCloseClick"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Severity" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding SeverityFilters}"
                              SelectedItem="{Binding SelectedSeverity}"
                              MinHeight="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="PLC Filter" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding PlcFilter, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="30"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Search" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="30"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#182235" MinHeight="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Severity" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="Time" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="PLC Name" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Category" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Message" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="Status" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                </Grid>

                <ScrollViewer x:Name="EventListScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#26364F" BorderThickness="0,0,0,1" MinHeight="46">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="86"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource SeverityBarStyle}"/>

                                        <Border Grid.Column="1" Style="{StaticResource SeverityBadgeStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding SeverityText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PlcName}" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Category}" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Message}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Status}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="12">
            <Grid>
                <TextBlock Text="{Binding DisplayCountText}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Clear View"
                            Command="{Binding ClearViewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="Export"
                            Command="{Binding ExportPlaceholderCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="AH-WPF-04 placeholder only. Export is not implemented."/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
