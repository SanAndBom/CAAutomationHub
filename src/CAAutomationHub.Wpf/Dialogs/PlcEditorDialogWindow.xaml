<Window x:Class="CAAutomationHub.Wpf.Dialogs.PlcEditorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="980"
        Height="880"
        MinWidth="900"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        Title="{Binding DialogTitle}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#202A3E"/>
            <Setter Property="BorderBrush" Value="#3E4C68"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding HeaderTitle}" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding HeaderSubtitle}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1"
                    Background="#202A3E"
                    BorderBrush="#3E4C68"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding TestStateDisplayName}" Foreground="{Binding TestStateBrush}" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="기본 정보" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="PLC 이름" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding PlcName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="라인 이름" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding LineName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="설명" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="네트워크 / 연결 설정" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="IP 주소" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Port" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="사용 여부" Style="{StaticResource FieldLabelStyle}"/>
                                    <CheckBox Content="ON / 사용"
                                              IsChecked="{Binding IsEnabled}"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="폴링 / 재연결 설정" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Polling Interval" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding PollingIntervalMsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                    <TextBlock Text="ms" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="Timeout" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding TimeoutMsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                    <TextBlock Text="ms" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="4">
                                    <TextBlock Text="재연결 간격" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding ReconnectIntervalSecText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                    <TextBlock Text="sec" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="최대 재시도" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding MaxRetryCountText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldValueTextBoxStyle}"/>
                                    <TextBlock Text="회" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Auto Reconnect" Style="{StaticResource FieldLabelStyle}"/>
                                    <CheckBox Content="ON"
                                              IsChecked="{Binding AutoReconnect}"
                                              Foreground="White"
                                              Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="동작 옵션" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="시작 시 자동 연결"
                                      IsChecked="{Binding ConnectOnStartup}"
                                      Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="연결 테스트 결과" Style="{StaticResource SectionTitleStyle}"/>
                        <ItemsControl ItemsSource="{Binding TestStateOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{Binding ForegroundBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="설정 요약" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="PLC 이름" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding PlcName}" Style="{StaticResource SummaryValueStyle}"/>
                        <TextBlock Text="IP 주소" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding IpAddress}" Style="{StaticResource SummaryValueStyle}"/>
                        <TextBlock Text="Port" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding PortText}" Style="{StaticResource SummaryValueStyle}"/>
                        <TextBlock Text="Polling Interval" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding PollingIntervalSummary}" Style="{StaticResource SummaryValueStyle}"/>
                        <TextBlock Text="Auto Reconnect" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding AutoReconnectSummary}" Style="{StaticResource SummaryValueStyle}"/>
                        <TextBlock Text="테스트 상태" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding TestStateDisplayName}" Foreground="{Binding TestStateBrush}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <Border Background="#3A2026"
                    BorderBrush="#C6505E"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10"
                    Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="저장할 수 없습니다" Foreground="#FFADB8" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="- " Foreground="#FFADB8"/>
                                    <TextBlock Text="{Binding}" Foreground="#FFADB8" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <DockPanel LastChildFill="False">
                <Button Content="취소"
                        Click="OnCancelClick"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="92"
                        Margin="0,0,8,0"/>
                <Button Content="테스트 연결"
                        Command="{Binding TestConnectionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="118"
                        Margin="0,0,8,0"/>
                <Button Content="저장"
                        Click="OnSaveClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="92"/>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
