<Application x:Class="CAAutomationHub.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Brushes.xaml" />
                <ResourceDictionary Source="Themes/ButtonStyles.xaml" />
                <ResourceDictionary Source="Themes/CardStyles.xaml" />
                <ResourceDictionary Source="Themes/StatusStyles.xaml" />
                <ResourceDictionary Source="Themes/ScrollBarStyles.xaml" />
                <ResourceDictionary Source="Themes/Theme.Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
