<Window x:Class="CAAutomationHub.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CAAutomationHub.Wpf.Views"
        Title="CAAutomationHub Dashboard"
        Width="1440"
        Height="900"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBackgroundBrush}" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="CAAutomationHub" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Grid.Column="1" Text="PLC Communication Monitor" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" />
            </Grid>
        </Border>
        <views:DashboardView />
    </DockPanel>
</Window>
