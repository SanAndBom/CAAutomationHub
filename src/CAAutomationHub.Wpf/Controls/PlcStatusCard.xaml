<UserControl x:Class="CAAutomationHub.Wpf.Controls.PlcStatusCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Width="220" Height="420" Padding="12,10,12,8">
        <Border.Style>
            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#2B3851"/>
                <Setter Property="Effect" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#53627A"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#30C5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.28"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding PlcName}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding LineName}" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,10" TextAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Ellipse Width="118" Height="118" StrokeThickness="8">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Stroke" Value="#4DA6FF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Warning">
                                    <Setter Property="Stroke" Value="#FFD84E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Congested">
                                    <Setter Property="Stroke" Value="#FF9A2E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Error">
                                    <Setter Property="Stroke" Value="#FF5555"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionState}" Value="Inactive">
                                    <Setter Property="Stroke" Value="#7D8794"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,3" CornerRadius="9" Background="#1E2E45">
                    <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#5CC8FF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Warning">
                                        <Setter Property="Foreground" Value="#FFD84E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Congested">
                                        <Setter Property="Foreground" Value="#FF9A2E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Error">
                                        <Setter Property="Foreground" Value="#FF5555"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Inactive">
                                        <Setter Property="Foreground" Value="#B5BEC9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>

            <Border Grid.Row="2" HorizontalAlignment="Center" Padding="8,2" CornerRadius="10" Background="#15311F" Margin="0,0,0,8">
                <TextBlock Text="● 온라인" Foreground="LightGreen" FontSize="14" FontWeight="SemiBold"/>
            </Border>

            <Border Grid.Row="3" Background="#1A2638" CornerRadius="4" Padding="7,3" Margin="0,0,0,7">
                <TextBlock Text="{Binding CurrentSequenceText}"
                           Foreground="White"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center"/>
            </Border>

            <Grid Grid.Row="4" Margin="0,0,0,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP / Port" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EndpointText}" Foreground="White"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Polling" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PollingIntervalText}" Foreground="White" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastResponseText}" Foreground="White" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="TX / RX" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TxRxText}" Foreground="White" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Error" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ErrorCount}" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorCount}" Value="0">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorCount}" Value="1">
                                    <Setter Property="Foreground" Value="Tomato"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Border Grid.Row="5" Background="#1A2638" CornerRadius="4" Padding="5,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="응답 지연" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="0" Text="5분" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                    <ItemsControl ItemsSource="{Binding SequenceResponseLatencyBuckets}"
                                  Grid.Row="1"
                                  Margin="0,2,0,0"
                                  Height="24"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Bottom">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="10"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Width="4"
                                               Height="{Binding StartBarHeight}"
                                               Fill="#63D98A"
                                               RadiusX="1"
                                               RadiusY="1"
                                               VerticalAlignment="Bottom"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,0.5,0"/>
                                    <Rectangle Grid.Column="1"
                                               Width="4"
                                               Height="{Binding CompletionBarHeight}"
                                               Fill="#4DA6FF"
                                               RadiusX="1"
                                               RadiusY="1"
                                               VerticalAlignment="Bottom"
                                               HorizontalAlignment="Left"
                                               Margin="0.5,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
