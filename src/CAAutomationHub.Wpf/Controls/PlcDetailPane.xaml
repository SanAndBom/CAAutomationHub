<UserControl x:Class="CAAutomationHub.Wpf.Controls.PlcDetailPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}" Padding="12">
        <StackPanel>
            <Grid>
                <TextBlock Text="선택된 PLC 상세 정보" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="수정"
                            Click="OnEditClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="64"
                            Margin="0,0,6,0"/>
                    <Button Content="삭제"
                            Click="OnDeleteClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="64"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="{Binding PlcName}" Foreground="White" FontSize="24" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding LineName}" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,14"/>

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionText}" Foreground="White"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="IP / Port" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EndpointText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Polling" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PollingIntervalText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Response" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastResponseText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="TX / RX" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TxRxText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Error Count" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ErrorCount}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Current Sequence" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentSequenceName}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Sequence Status" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentSequenceStatusText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Elapsed" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentSequenceElapsedText}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Last Message" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="9" Grid.Column="1"
                           Text="{Binding LastSequenceMessage}"
                           Foreground="White"
                           Margin="0,8,0,0"
                           MaxWidth="170"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Border Background="#1A2638" CornerRadius="4" Padding="10">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="최근 이벤트" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="전체 보기"
                                Click="OnOpenEventLogClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock Text="실시간 이벤트 로그는 AH-WPF-04 Prototype 창에서 확인합니다."
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
