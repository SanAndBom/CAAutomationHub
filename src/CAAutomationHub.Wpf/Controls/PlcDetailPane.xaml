<UserControl x:Class="CAAutomationHub.Wpf.Controls.PlcDetailPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}" Padding="12">
        <StackPanel>
            <TextBlock Text="선택된 PLC 상세 정보" Foreground="White" FontSize="16"/>
            <TextBlock Text="{Binding PlcName}" Foreground="White" FontSize="24" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding LineName}" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,14"/>

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Snapshot.ConnectionState}" Foreground="White"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="IP / Port" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="White" Margin="0,8,0,0">
                    <Run Text="{Binding Snapshot.IpAddress}"/><Run Text=":"/><Run Text="{Binding Snapshot.Port}"/>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Polling" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Snapshot.PollingIntervalMs, StringFormat={}{0}ms}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Response" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Snapshot.LastResponseMs, StringFormat={}{0}ms}" Foreground="White" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="TX / RX" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="White" Margin="0,8,0,0">
                    <Run Text="{Binding Snapshot.TxPerMinute}"/><Run Text=" / "/><Run Text="{Binding Snapshot.RxPerMinute}"/>
                </TextBlock>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Error Count" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Snapshot.ErrorCount}" Foreground="White" Margin="0,8,0,0"/>
            </Grid>

            <Border Background="#1A2638" CornerRadius="4" Padding="10">
                <TextBlock Text="제어 작업과 이벤트 로그는 후속 범위에서 연결됩니다." Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
