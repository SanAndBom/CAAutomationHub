<UserControl x:Class="CAAutomationHub.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CAAutomationHub.Wpf.Controls"
             xmlns:vm="clr-namespace:CAAutomationHub.Wpf.ViewModels"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="PlcCardButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:DashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="PLC 통신 상태 개요" FontSize="28" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="전체" Foreground="White" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding TotalCount}" Foreground="#50B2FF" FontSize="32" FontWeight="SemiBold" Margin="0,0,22,0"/>
                    <TextBlock Text="정상" Foreground="LightGreen" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding HealthyCount}" Foreground="LightGreen" FontSize="32" FontWeight="SemiBold" Margin="0,0,22,0"/>
                    <TextBlock Text="주의" Foreground="Khaki" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding WarningCount}" Foreground="Khaki" FontSize="32" FontWeight="SemiBold" Margin="0,0,22,0"/>
                    <TextBlock Text="정체" Foreground="Orange" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CongestedCount}" Foreground="Orange" FontSize="32" FontWeight="SemiBold" Margin="0,0,22,0"/>
                    <TextBlock Text="오류" Foreground="Tomato" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ErrorCount}" Foreground="Tomato" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="새로고침" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="+ PLC 추가" Click="OnAddPlcClick" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="236"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding DetailPaneGapWidth}"/>
                <ColumnDefinition Width="{Binding DetailPaneColumnWidth}"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10,8,10,10" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                <ScrollViewer x:Name="PlcCardScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              PreviewMouseLeftButtonDown="OnPlcCardScrollViewerPreviewMouseLeftButtonDown"
                              PreviewMouseMove="OnPlcCardScrollViewerPreviewMouseMove"
                              PreviewMouseLeftButtonUp="OnPlcCardScrollViewerPreviewMouseLeftButtonUp"
                              PreviewMouseWheel="OnPlcCardScrollViewerPreviewMouseWheel">
                    <ItemsControl ItemsSource="{Binding PlcCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectPlcCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource PlcCardButtonStyle}">
                                    <controls:PlcStatusCard/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" HorizontalAlignment="Stretch">
                <controls:CommunicationTrendChart Trend="{Binding CurrentCommunicationTrend}"
                                                   AverageResponseMs="{Binding TrendAverageResponseMs}"
                                                   MaxResponseMs="{Binding TrendMaxResponseMs}"
                                                   ErrorCount="{Binding TrendErrorCount}"
                                                   PointCount="{Binding TrendPointCount}"/>
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="10" Visibility="{Binding IsDetailPaneOpen, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="✕" HorizontalAlignment="Right" Command="{Binding CloseDetailPaneCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                    <controls:PlcDetailPane Grid.Row="1" DataContext="{Binding SelectedPlc}" Margin="0,6,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
