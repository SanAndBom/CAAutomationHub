<UserControl x:Class="CAAutomationHub.Wpf.Views.Pilot.WorkStartPilotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="WorkStart Pilot"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TargetId, StringFormat=Target: {0}}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="착공 실행"
                        Style="{StaticResource SecondaryButtonStyle}"
                        IsEnabled="False"
                        MinWidth="92"
                        VerticalAlignment="Top"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A2638" CornerRadius="4" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Busy" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding IsBusy}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#1A2638" CornerRadius="4" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Status" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding LastStatus, TargetNullValue=-}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#1A2638" CornerRadius="4" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Succeeded" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding LastSucceeded, TargetNullValue=-}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Step" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastStep, TargetNullValue=-}" Foreground="White" Margin="0,0,24,8"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="LOT ID" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedLotId, TargetNullValue=-}" Foreground="White" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Error Code" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastErrorCode, TargetNullValue=-}" Foreground="White" Margin="0,0,24,8"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Error Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LastErrorCodeName, TargetNullValue=-}" Foreground="White" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Error Write" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastErrorWriteExpected}" Foreground="White" Margin="0,0,24,8"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Duration" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding LastDuration, TargetNullValue=-}" Foreground="White" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Started" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastStartedAt, TargetNullValue=-}" Foreground="White" Margin="0,0,24,8"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Completed" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,8"/>
                <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding LastCompletedAt, TargetNullValue=-}" Foreground="White" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Message" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,0"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding LastMessage, TargetNullValue=-}"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
